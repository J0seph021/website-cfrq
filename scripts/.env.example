# Pipeline d'export des cartes (scripts/export-cartes.mjs) — NE PAS COMMITER le vrai .env
# Connexion lecture seule à PlaniLogix (PostGIS)
PLANILOGIX_DB_URL=postgresql://user:pass@host:5432/postgres

# Supabase du site (projet "Relevés forestiers")
SUPABASE_URL=https://sfzcslpbysabsiszcpqm.supabase.co
# Clé service_role (Supabase > Project Settings > API). Secrète: jamais dans le navigateur ni le dépôt.
SUPABASE_SERVICE_ROLE_KEY=

# Projet Supabase PlaniLogix (source des PDF) — pour scripts/copy-documents.mjs
PLANI_URL=https://bpxzznykbikbqbvraqxj.supabase.co
PLANI_STORAGE_KEY=
PLANI_DOC_BUCKET=centre_documentaire

# --- Edge Function sync-documents (couche 2 automatisée) ---
# Mêmes valeurs que ci-dessus, posées comme SECRETS de la fonction (jamais dans le dépôt) :
#   supabase secrets set --project-ref sfzcslpbysabsiszcpqm \
#     PLANILOGIX_DB_URL=... PLANI_URL=... PLANI_STORAGE_KEY=... SYNC_SECRET=...
# SUPABASE_URL et SUPABASE_SERVICE_ROLE_KEY sont injectés automatiquement par Supabase.
# SYNC_SECRET = chaîne aléatoire partagée cron <-> fonction (en-tête x-sync-secret).
SYNC_SECRET=
