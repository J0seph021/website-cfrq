---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
import { withBase } from "../lib/url";
import boiseMature from "../assets/photos/boise-mature.jpg";
import photoEquipe from "../assets/photos/equipe.jpg";

// Numéros de poste tirés de l'annuaire téléphonique interne (2026-07).
const equipe = [
  { nom: "Alexandra Fortier", titre: "Réception", poste: "750", ing: false },
  { nom: "Camay Boisvert", titre: "Ingénieure forestière", poste: "752", ing: true },
  { nom: "Cédric Maheu", titre: "Ingénieur forestier", poste: "766", ing: true },
  { nom: "Joseph Moffet", titre: "Ingénieur forestier", poste: "751", ing: true },
  { nom: "Sébastien Rioux", titre: "Ingénieur forestier", poste: "753", ing: true },
  { nom: "Simon Proulx", titre: "Ingénieur forestier", poste: "754", ing: true },
];

const valeurs = [
  { titre: "Un conseil indépendant", texte: "On recommande ce qui est bon pour votre forêt, pas pour un tiers. Vos objectifs passent avant tout." },
  { titre: "Ingénieurs & techniciens", texte: "Des techniciens sur le terrain et des ingénieurs forestiers qui signent vos plans et rapports." },
  { titre: "Du diagnostic aux travaux", texte: "Un seul interlocuteur, de la première visite jusqu'à la réalisation des interventions." },
  { titre: "On maximise vos aides", texte: "On connaît les programmes et on monte les demandes avec vous, pour réduire vos coûts." },
];

const accreditations = [
  "Accrédité auprès des 6 agences régionales de mise en valeur des forêts privées, depuis 1996",
  "Plans et rapports signés par des ingénieurs forestiers",
  "Partenaire des programmes de mise en valeur des forêts privées",
];

// Chips territoire : 6 régions + un chip combiné Chaudière · Appalaches.
const chipsTerritoire = [...site.regions.slice(0, 6), site.regions.slice(6).join(" · ")];

const ld = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebPage", "@id": "https://cfrq.ca/a-propos-de-nous/#webpage", url: "https://cfrq.ca/a-propos-de-nous/", name: "À propos | CFRQ", description: "L'équipe, la mission et l'accréditation de CFRQ, conseiller forestier depuis 1996.", inLanguage: "fr-CA", about: { "@id": "https://cfrq.ca/#organization" } },
    { "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: "https://cfrq.ca/" },
      { "@type": "ListItem", position: 2, name: "À propos", item: "https://cfrq.ca/a-propos-de-nous/" },
    ] },
    { "@type": "Organization", "@id": "https://cfrq.ca/#organization", name: "Conseillers Forestiers de la Région de Québec inc.", alternateName: "CFRQ", foundingDate: "1996", employee: equipe.map((m) => ({ "@type": "Person", name: m.nom, jobTitle: m.titre })) },
  ],
};

const eyebrow = "text-[12.5px] font-semibold uppercase tracking-[0.18em]";
const hatch = "background:repeating-linear-gradient(135deg,#E7EEDA,#E7EEDA 8px,#EEF3E5 8px,#EEF3E5 16px)";
---

<Base
  title="À propos : notre équipe et notre mission depuis 1996 | CFRQ"
  description="Depuis 1996, CFRQ accompagne les propriétaires de boisés privés. Notre équipe d'ingénieurs et de techniciens forestiers accrédités auprès des 6 agences régionales."
  canonical="/a-propos-de-nous/"
>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} slot="head" />

  <Header />
  <main id="contenu">
    <!-- HERO -->
    <section class="relative isolate overflow-hidden bg-[#16200f]">
      <Image src={boiseMature} alt="Forêt privée mature" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10" style="background:linear-gradient(120deg,rgba(15,22,10,.9) 0%,rgba(15,22,10,.66) 55%,rgba(15,22,10,.3) 100%)"></div>
      <div class="mx-auto max-w-[1160px] px-[22px] py-[88px]">
        <div class="max-w-[640px]">
          <p class={`${eyebrow} tracking-[0.2em] text-cfrq-green-light`}>À propos</p>
          <h1 class="mt-3 font-display font-medium text-cfrq-cream text-[clamp(38px,6.5vw,58px)] leading-[1.03] tracking-[-0.02em] text-balance">
            Vos forêts, notre métier depuis 1996
          </h1>
          <p class="mt-5 max-w-[560px] text-[19px] leading-[1.55] text-[#dce2d2]">
            Conseiller forestier accrédité de la région de Québec, nous aidons les propriétaires à comprendre, mettre en valeur et transmettre leur boisé, du premier diagnostic jusqu'aux travaux.
          </p>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <section class="bg-cfrq-deep text-cfrq-cream">
      <div class="mx-auto grid max-w-[1160px] grid-cols-2 gap-[22px] px-[22px] py-[30px] md:grid-cols-4">
        {site.stats.map((s) => (
          <div>
            <p class="font-display text-[30px] font-medium leading-none">{s.valeur}</p>
            <p class="mt-1 text-[13px] text-cfrq-cream/65">{s.label}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- MISSION -->
    <section class="mx-auto max-w-[900px] px-[22px] pb-5 pt-[84px]">
      <p class={`${eyebrow} text-cfrq-leaf`}>Notre mission</p>
      <p class="mt-4 font-display text-[clamp(24px,3.6vw,34px)] font-normal leading-[1.32] text-cfrq-deep text-pretty">
        Rendre l'aménagement forestier <em class="not-italic text-cfrq-leaf">simple, accessible et payant</em> pour chaque propriétaire, qu'il possède un petit boisé de loisir ou une grande forêt productive.
      </p>
      <p class="mt-[26px] text-[17px] leading-[1.7] text-cfrq-ink/[.72]">
        Depuis près de 30 ans, nos ingénieurs et techniciens forestiers accompagnent les propriétaires de la grande région de Québec. On va sur le terrain, on explique sans jargon, on signe des plans rigoureux et on réalise les travaux. Notre indépendance nous permet de toujours recommander ce qui sert vraiment votre forêt et vos objectifs.
      </p>
    </section>

    <!-- VALEURS -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-5 pt-[60px]">
      <div class="grid gap-[18px] sm:grid-cols-2 lg:grid-cols-4">
        {valeurs.map((v) => (
          <div class="rounded-[18px] border border-black/5 bg-white p-[26px]">
            <h2 class="font-display text-[20px] font-medium text-cfrq-deep">{v.titre}</h2>
            <p class="mt-2.5 text-[14.5px] leading-relaxed text-cfrq-ink/65">{v.texte}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- EQUIPE -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-5 pt-[72px]">
      <div class="max-w-[640px]">
        <p class={`${eyebrow} text-cfrq-leaf`}>Notre équipe</p>
        <h2 class="mt-3.5 font-display font-medium text-cfrq-deep text-[clamp(30px,4.5vw,42px)] leading-[1.05] tracking-[-0.015em] text-balance">Des gens de forêt, près de chez vous</h2>
        <p class="mt-4 text-[16px] leading-relaxed text-cfrq-ink/65">
          Des ingénieurs forestiers qui signent vos plans et rapports, appuyés par des techniciens
          présents dans chaque secteur. Ce sont eux qui se déplacent sur votre propriété, de la
          première visite jusqu'aux travaux.
        </p>
      </div>
      <Image
        src={photoEquipe}
        alt="L'équipe de CFRQ réunie en plein air"
        widths={[768, 1195]}
        sizes="(min-width: 1204px) 1116px, 100vw"
        class="mt-[38px] aspect-[16/9] w-full rounded-[22px] border border-black/5 object-cover"
      />
      <div class="mt-[26px] grid gap-[14px] sm:grid-cols-2 lg:grid-cols-3">
        {equipe.map((m) => (
          <div class="rounded-[18px] border border-black/5 bg-white px-[22px] py-[18px]">
            <p class="font-display text-[18px] text-cfrq-deep">
              {m.nom}{m.ing && <span class="text-cfrq-leaf">, ing.f.</span>}
            </p>
            <p class="mt-0.5 text-[13.5px] text-cfrq-ink/65">{m.titre}</p>
            <a
              class="mt-2 inline-block text-[14.5px] font-medium text-cfrq-leaf underline-offset-2 hover:underline"
              href={`tel:+13677770555,${m.poste}`}
            >
              {site.tel}, poste {m.poste}
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- ACCREDITATIONS + TERRITOIRE -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-5 pt-[72px]">
      <div class="flex flex-wrap gap-[18px]">
        <div class="flex-1 basis-[300px] rounded-[22px] border border-cfrq-green/[.14] bg-[#eef2e6] p-[30px]">
          <p class="text-[12px] font-bold uppercase tracking-[0.14em] text-cfrq-leaf">Accréditations</p>
          <ul class="mt-4 space-y-3">
            {accreditations.map((a) => (
              <li class="flex items-start gap-[11px]">
                <span class="mt-[7px] h-[7px] w-[7px] flex-none rounded-full bg-cfrq-green"></span>
                <span class="text-[15px] leading-[1.5] text-cfrq-ink">{a}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="flex-1 basis-[300px] rounded-[22px] border border-black/5 bg-white p-[30px]">
          <p class="text-[12px] font-bold uppercase tracking-[0.14em] text-cfrq-leaf">Territoire desservi</p>
          <div class="mt-4 flex flex-wrap gap-[9px]">
            {chipsTerritoire.map((r) => (
              <span class="rounded-full bg-cfrq-tint px-3.5 py-2 text-[14px] font-medium text-cfrq-deep">{r}</span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-[84px] pt-[72px]">
      <div class="rounded-3xl px-[clamp(34px,5vw,56px)] py-[clamp(34px,5vw,56px)] text-center text-cfrq-cream" style="background:linear-gradient(140deg,#1D4011,#14331A)">
        <h2 class="font-display text-[clamp(28px,4.5vw,44px)] font-medium leading-[1.06] text-balance">Faisons connaissance</h2>
        <p class="mx-auto mt-4 max-w-[520px] text-[18px] leading-[1.55] text-cfrq-cream/[.82]">
          Une visite-conseil de votre boisé, c'est le meilleur point de départ.
        </p>
        <div class="mt-[30px] flex flex-wrap items-center justify-center gap-4">
          <a href={withBase("/contact")} class="inline-flex items-center rounded-xl bg-cfrq-green px-8 py-4 text-[16.5px] font-bold text-[#123005] transition-colors hover:bg-[#6ecb3e]">
            Réserver une visite-conseil
          </a>
          <p class="text-[16px] text-cfrq-cream/85">ou&nbsp;<a href={site.telHref} class="font-semibold text-cfrq-cream hover:underline">{site.tel}</a></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
