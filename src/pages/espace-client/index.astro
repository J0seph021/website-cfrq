---
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Logo from "../../components/Logo.astro";
import { withBase } from "../../lib/url";
import { site } from "../../data/site";
import boise from "../../assets/photos/boise-mature.jpg";

const inputClass =
  "h-[50px] w-full rounded-[10px] border border-black/15 bg-white px-[15px] text-[16px] outline-none transition-shadow focus:border-cfrq-green focus:shadow-[0_0_0_3px_rgba(90,189,42,.18)]";
const linkClass = "text-cfrq-leaf underline-offset-2 hover:text-cfrq-green hover:underline";
---

<Base
  title="Connexion à l'espace client | CFRQ"
  description="Connectez-vous à votre espace client CFRQ pour suivre vos dossiers forestiers."
  robots="noindex, follow"
>
  <main id="contenu" class="relative flex min-h-screen items-center justify-center overflow-hidden px-5 py-10">
    <Image src={boise} alt="" widths={[768, 1280, 1920]} sizes="100vw" class="absolute inset-0 -z-10 h-full w-full object-cover" />
    <div class="absolute inset-0 -z-10" style="background:linear-gradient(160deg,rgba(15,22,10,.92),rgba(20,51,26,.86))"></div>

    <div class="w-full max-w-[430px] rounded-[22px] bg-white px-9 py-10 shadow-[0_30px_70px_rgba(0,0,0,.4)]">
      <a href={withBase("/")} class="flex justify-center text-cfrq-ink" aria-label="Accueil CFRQ">
        <Logo class="h-10 w-auto" />
      </a>
      <h1 id="titre" class="mt-6 text-center font-display text-[27px] font-medium text-cfrq-deep">Connexion</h1>
      <p id="sous-titre" class="mt-1.5 text-center text-[15px] text-cfrq-ink/60">Accédez à vos documents, cartes et relevés forestiers.</p>

      <form id="login-form" class="mt-[26px]" novalidate>
        <div id="bloc-courriel">
          <label for="courriel" class="mb-1.5 block text-[13.5px] font-semibold text-cfrq-deep">Courriel</label>
          <input id="courriel" class={inputClass} type="email" name="courriel" placeholder="vous@exemple.ca" autocomplete="email" aria-label="Courriel" required />
        </div>

        <div id="bloc-mdp" class="mt-4 hidden">
          <div class="mb-1.5 flex items-baseline justify-between">
            <label for="mdp" class="block text-[13.5px] font-semibold text-cfrq-deep">Mot de passe</label>
            <button type="button" id="lien-oubli" class={`text-[13px] ${linkClass} hidden`}>Mot de passe oublié ?</button>
          </div>
          <input id="mdp" class={inputClass} type="password" name="mdp" placeholder="••••••••" autocomplete="current-password" aria-label="Mot de passe" minlength="8" />
          <p id="aide-mdp" class="mt-1.5 hidden text-[12.5px] text-cfrq-ink/55">8 caractères ou plus.</p>
        </div>

        <button id="btn" type="submit" class="mt-5 w-full rounded-[10px] bg-cfrq-green px-6 py-[15px] text-[16px] font-bold text-[#123005] transition-colors hover:bg-cfrq-green-hover disabled:opacity-60">
          Envoyer le lien
        </button>
        <p id="msg" class="mt-3 text-center text-[14px] leading-relaxed text-cfrq-leaf" role="status" aria-live="polite"></p>
      </form>

      <!-- Bascule entre lien magique et mot de passe -->
      <p id="ligne-methode" class="mt-4 text-center text-[14px] text-cfrq-ink/70">
        <button type="button" id="toggle-methode" class={linkClass}>Se connecter par mot de passe</button>
      </p>

      <!-- Créer un compte / j'ai déjà un compte -->
      <p id="ligne-compte" class="mt-2 text-center text-[14px] text-cfrq-ink/70">
        Pas encore de compte ? <button type="button" id="toggle-compte" class={`font-semibold ${linkClass}`}>Créez votre espace client</button>
      </p>

      <!-- Note lien magique (masquée dans les autres modes) -->
      <div id="note-magique" class="mt-5 flex items-start gap-2.5 rounded-xl border border-cfrq-green/20 bg-[#f3f7ec] px-4 py-3.5">
        <span class="mt-1.5 h-[7px] w-[7px] flex-none rounded-full bg-cfrq-green"></span>
        <p class="text-[13px] leading-[1.5] text-cfrq-ink/70">
          Pas de mot de passe à retenir : on vous envoie un <strong class="font-semibold text-cfrq-deep">lien de connexion par courriel</strong> pour accéder à votre espace en un clic.
        </p>
      </div>

      <a href={withBase("/")} class="mt-[22px] block text-center text-[14px] text-cfrq-leaf hover:text-cfrq-green">
        ← Retour au site
      </a>
    </div>

    <p class="absolute inset-x-0 bottom-[18px] text-center text-[12px] text-cfrq-cream/55">
      Une question ? Appelez-nous au {site.tel}
    </p>
  </main>
</Base>

<script>
  import { supabase } from "../../lib/supabaseClient";
  import { withBase } from "../../lib/url";

  type Mode = "magique" | "mdp" | "inscription" | "nouveau-mdp";

  // Capté immédiatement: detectSessionInUrl nettoie le fragment de façon asynchrone.
  // Sur cette page, seul le lien de réinitialisation arrive avec un jeton dans le
  // fragment (le lien magique, lui, pointe vers le tableau de bord).
  const retourAvecJeton = location.hash.includes("access_token");

  const dashboardPath = withBase("/espace-client/tableau-de-bord");
  const loginPath = withBase("/espace-client");
  // URLs absolues calculées au runtime: fonctionne en local, en préproduction
  // GitHub Pages et sur cfrq.ca sans reconfiguration.
  const dashboardUrl = new URL(dashboardPath, location.origin).href;
  const loginUrl = new URL(loginPath, location.origin).href;

  const $ = <T extends HTMLElement>(id: string) => document.getElementById(id) as T;
  const form = $<HTMLFormElement>("login-form");
  const titre = $("titre");
  const sousTitre = $("sous-titre");
  const blocMdp = $("bloc-mdp");
  const aideMdp = $("aide-mdp");
  const lienOubli = $<HTMLButtonElement>("lien-oubli");
  const btn = $<HTMLButtonElement>("btn");
  const msg = $("msg");
  const courrielEl = $<HTMLInputElement>("courriel");
  const mdpEl = $<HTMLInputElement>("mdp");
  const ligneMethode = $("ligne-methode");
  const ligneCompte = $("ligne-compte");
  const toggleMethode = $<HTMLButtonElement>("toggle-methode");
  const toggleCompte = $<HTMLButtonElement>("toggle-compte");
  const noteMagique = $("note-magique");

  let mode: Mode = "magique";

  const show = (el: HTMLElement, on: boolean) => el.classList.toggle("hidden", !on);
  function setMsg(text = "", ton: "info" | "erreur" = "info") {
    msg.textContent = text;
    msg.classList.toggle("text-cfrq-leaf", ton === "info");
    msg.classList.toggle("text-red-600", ton === "erreur");
  }

  const CONFIG: Record<Mode, { titre: string; sousTitre: string; btn: string }> = {
    magique: {
      titre: "Connexion",
      sousTitre: "Accédez à vos documents, cartes et relevés forestiers.",
      btn: "Envoyer le lien",
    },
    mdp: {
      titre: "Connexion",
      sousTitre: "Accédez à vos documents, cartes et relevés forestiers.",
      btn: "Se connecter",
    },
    inscription: {
      titre: "Créer votre espace",
      sousTitre: "Choisissez un mot de passe pour créer votre espace client.",
      btn: "Créer mon espace",
    },
    "nouveau-mdp": {
      titre: "Nouveau mot de passe",
      sousTitre: "Choisissez votre nouveau mot de passe.",
      btn: "Enregistrer le mot de passe",
    },
  };

  function setMode(next: Mode) {
    mode = next;
    setMsg("");
    const c = CONFIG[next];
    titre.textContent = c.titre;
    sousTitre.textContent = c.sousTitre;
    btn.textContent = c.btn;

    const veutMdp = next === "mdp" || next === "inscription" || next === "nouveau-mdp";
    show(blocMdp, veutMdp);
    show(aideMdp, next === "inscription" || next === "nouveau-mdp");
    show(lienOubli, next === "mdp");
    mdpEl.autocomplete = next === "mdp" ? "current-password" : "new-password";

    // Le courriel est inutile quand on définit un nouveau mot de passe (session déjà ouverte via le lien de récupération).
    show($("bloc-courriel"), next !== "nouveau-mdp");
    show(noteMagique, next === "magique");
    show(ligneMethode, next === "magique" || next === "mdp");
    show(ligneCompte, next === "magique" || next === "mdp" || next === "inscription");

    toggleMethode.textContent = next === "mdp" ? "Recevoir plutôt un lien par courriel" : "Se connecter par mot de passe";
    ligneCompte.innerHTML =
      next === "inscription"
        ? 'Déjà un compte ? <button type="button" id="toggle-compte" class="font-semibold text-cfrq-leaf underline-offset-2 hover:text-cfrq-green hover:underline">Se connecter</button>'
        : 'Pas encore de compte ? <button type="button" id="toggle-compte" class="font-semibold text-cfrq-leaf underline-offset-2 hover:text-cfrq-green hover:underline">Créez votre espace client</button>';
    $<HTMLButtonElement>("toggle-compte").addEventListener("click", () =>
      setMode(mode === "inscription" ? "magique" : "inscription"),
    );

    if (next === "nouveau-mdp") mdpEl.focus();
  }

  toggleMethode.addEventListener("click", () => setMode(mode === "mdp" ? "magique" : "mdp"));
  toggleCompte.addEventListener("click", () => setMode("inscription"));
  lienOubli.addEventListener("click", () => envoyerReinitialisation());

  async function envoyerReinitialisation() {
    const email = courrielEl.value.trim();
    if (!email) { setMsg("Entrez d'abord votre courriel.", "erreur"); courrielEl.focus(); return; }
    btn.disabled = true;
    const { error } = await supabase.auth.resetPasswordForEmail(email, { redirectTo: loginUrl });
    btn.disabled = false;
    if (error) { setMsg("Une erreur est survenue. Réessayez.", "erreur"); return; }
    setMsg("Lien de réinitialisation envoyé. Vérifiez vos courriels (et les indésirables).");
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = courrielEl.value.trim();
    const mdp = mdpEl.value;
    btn.disabled = true;
    setMsg("");

    try {
      if (mode === "magique") {
        if (!email) { setMsg("Entrez votre courriel.", "erreur"); return; }
        const { error } = await supabase.auth.signInWithOtp({
          email,
          options: { shouldCreateUser: true, emailRedirectTo: dashboardUrl },
        });
        if (error) throw error;
        setMsg("Lien envoyé. Ouvrez votre courriel (et les indésirables) pour vous connecter.");
      } else if (mode === "mdp") {
        if (!email || !mdp) { setMsg("Entrez votre courriel et votre mot de passe.", "erreur"); return; }
        const { error } = await supabase.auth.signInWithPassword({ email, password: mdp });
        if (error) throw error;
        location.href = dashboardPath;
        return;
      } else if (mode === "inscription") {
        if (!email) { setMsg("Entrez votre courriel.", "erreur"); return; }
        if (mdp.length < 8) { setMsg("Le mot de passe doit compter au moins 8 caractères.", "erreur"); return; }
        const { data, error } = await supabase.auth.signUp({
          email,
          password: mdp,
          options: { emailRedirectTo: dashboardUrl },
        });
        if (error) throw error;
        if (data.session) { location.href = dashboardPath; return; }
        setMsg("Espace créé. Confirmez votre courriel avec le lien qu'on vient de vous envoyer.");
      } else if (mode === "nouveau-mdp") {
        if (mdp.length < 8) { setMsg("Le mot de passe doit compter au moins 8 caractères.", "erreur"); return; }
        const { error } = await supabase.auth.updateUser({ password: mdp });
        if (error) throw error;
        location.href = dashboardPath;
        return;
      }
    } catch (err: any) {
      setMsg(messageErreur(err?.message), "erreur");
    } finally {
      btn.disabled = false;
    }
  });

  // Traduit les messages Supabase les plus courants.
  function messageErreur(raw?: string): string {
    const m = (raw || "").toLowerCase();
    if (m.includes("invalid login")) return "Courriel ou mot de passe incorrect.";
    if (m.includes("already registered") || m.includes("already been registered"))
      return "Ce courriel a déjà un compte. Connectez-vous plutôt.";
    if (m.includes("rate limit") || m.includes("too many")) return "Trop de tentatives. Patientez un moment.";
    if (m.includes("password")) return "Mot de passe invalide (au moins 8 caractères).";
    return "Une erreur est survenue. Réessayez.";
  }

  // Le lien de réinitialisation ouvre une session temporaire et déclenche PASSWORD_RECOVERY:
  // on bascule vers le formulaire « nouveau mot de passe » au lieu de rediriger.
  supabase.auth.onAuthStateChange((event) => {
    if (event === "PASSWORD_RECOVERY") setMode("nouveau-mdp");
  });

  // Déjà connecté (et pas en train de réinitialiser) -> tableau de bord.
  if (!retourAvecJeton) {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) location.replace(dashboardPath);
  }
</script>
