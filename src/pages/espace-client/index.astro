---
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Logo from "../../components/Logo.astro";
import { withBase } from "../../lib/url";
import { site } from "../../data/site";
import boise from "../../assets/photos/boise-mature.jpg";

const inputClass =
  "h-[50px] w-full rounded-[10px] border border-black/15 bg-white px-[15px] text-[16px] outline-none transition-shadow focus:border-cfrq-green focus:shadow-[0_0_0_3px_rgba(90,189,42,.18)]";
---

<Base
  title="Connexion à l'espace client | CFRQ"
  description="Connectez-vous à votre espace client CFRQ pour suivre vos dossiers forestiers."
  robots="noindex, follow"
>
  <main id="contenu" class="relative flex min-h-screen items-center justify-center overflow-hidden px-5 py-10">
    <Image src={boise} alt="" widths={[768, 1280, 1920]} sizes="100vw" class="absolute inset-0 -z-10 h-full w-full object-cover" />
    <div class="absolute inset-0 -z-10" style="background:linear-gradient(160deg,rgba(15,22,10,.92),rgba(20,51,26,.86))"></div>

    <div class="w-full max-w-[430px] rounded-[22px] bg-white px-9 py-10 shadow-[0_30px_70px_rgba(0,0,0,.4)]">
      <a href={withBase("/")} class="flex justify-center text-cfrq-ink" aria-label="Accueil CFRQ">
        <Logo class="h-10 w-auto" />
      </a>
      <h1 class="mt-6 text-center font-display text-[27px] font-medium text-cfrq-deep">Espace client</h1>
      <p class="mt-1.5 text-center text-[15px] text-cfrq-ink/60">Votre relevé forestier, en ligne.</p>

      <form id="login-form" class="mt-[26px]">
        <label for="courriel" class="mb-1.5 block text-[13.5px] font-semibold text-cfrq-deep">Votre courriel</label>
        <input id="courriel" class={inputClass} type="email" name="courriel" placeholder="vous@exemple.ca" autocomplete="email" aria-label="Votre courriel" required />
        <div id="bloc-code" class="mt-4 hidden">
          <label for="code" class="mb-1.5 block text-[13.5px] font-semibold text-cfrq-deep">Code reçu par courriel</label>
          <input id="code" class={inputClass} inputmode="numeric" autocomplete="one-time-code" placeholder="123456" aria-label="Code de connexion" />
        </div>
        <button id="btn" type="submit" class="mt-4 w-full rounded-[10px] bg-cfrq-green px-6 py-[15px] text-[16px] font-bold text-[#123005] transition-colors hover:bg-cfrq-green-hover disabled:opacity-60">
          Recevoir mon code
        </button>
        <p id="msg" class="mt-3 text-center text-[14px] leading-relaxed text-cfrq-leaf" role="status" aria-live="polite"></p>
      </form>

      <div class="mt-5 flex items-start gap-2.5 rounded-xl border border-cfrq-green/20 bg-[#f3f7ec] px-4 py-3.5">
        <span class="mt-1.5 h-[7px] w-[7px] flex-none rounded-full bg-cfrq-green"></span>
        <p class="text-[13px] leading-[1.5] text-cfrq-ink/70">
          Pas de mot de passe à retenir : on vous envoie un <strong class="font-semibold text-cfrq-deep">code par courriel</strong> pour vous connecter en toute sécurité.
        </p>
      </div>

      <a href={withBase("/")} class="mt-[22px] block text-center text-[14px] text-cfrq-leaf hover:text-cfrq-green">
        ← Retour au site
      </a>
    </div>

    <p class="absolute inset-x-0 bottom-[18px] text-center text-[12px] text-cfrq-cream/55">
      Une question ? Appelez-nous au {site.tel}
    </p>
  </main>
</Base>

<script>
  import { supabase } from "../../lib/supabaseClient";
  import { withBase } from "../../lib/url";

  const dashboard = withBase("/espace-client/tableau-de-bord");
  const f = document.getElementById("login-form") as HTMLFormElement;
  const blocCode = document.getElementById("bloc-code")!;
  const btn = document.getElementById("btn")!;
  const msg = document.getElementById("msg")!;
  const courrielEl = document.getElementById("courriel") as HTMLInputElement;
  const codeEl = document.getElementById("code") as HTMLInputElement;
  let etape: "email" | "code" = "email";

  const { data: { session } } = await supabase.auth.getSession();
  if (session) location.replace(dashboard);

  f.addEventListener("submit", async (e) => {
    e.preventDefault();
    const email = courrielEl.value.trim();
    if (!email) return;
    btn.setAttribute("disabled", "true");

    if (etape === "email") {
      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { shouldCreateUser: true },
      });
      btn.removeAttribute("disabled");
      if (error) { msg.textContent = "Une erreur est survenue. Réessayez."; return; }
      etape = "code";
      blocCode.classList.remove("hidden");
      btn.textContent = "Se connecter";
      courrielEl.setAttribute("readonly", "true");
      msg.textContent = "Code envoyé. Vérifiez vos courriels (et les indésirables).";
      codeEl.focus();
    } else {
      const token = codeEl.value.trim();
      const { error } = await supabase.auth.verifyOtp({ email, token, type: "email" });
      btn.removeAttribute("disabled");
      if (error) { msg.textContent = "Code invalide ou expiré. Réessayez."; return; }
      location.href = dashboard;
    }
  });
</script>
