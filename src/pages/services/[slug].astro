---
import { Image } from "astro:assets";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageHeader from "../../components/PageHeader.astro";
import CTASection from "../../components/CTASection.astro";
import { services, type Service } from "../../data/services";
import { withBase } from "../../lib/url";

import peuplement from "../../assets/photos/peuplement.jpg";
import foretTravaux from "../../assets/photos/foret-travaux.jpg";
import erabliere from "../../assets/photos/erabliere.jpg";
import heroRecolte from "../../assets/photos/hero-recolte.jpg";
import territoire from "../../assets/photos/territoire.jpg";

const imgMap = {
  peuplement,
  "foret-travaux": foretTravaux,
  erabliere,
  "hero-recolte": heroRecolte,
  territoire,
};

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

interface Props {
  service: Service;
}
const { service } = Astro.props;
const img = imgMap[service.image];
const autres = services.filter((s) => s.slug !== service.slug).slice(0, 3);
---

<Base title={`${service.titre} — CFRQ`} description={service.intro}>
  <Header />
  <main id="contenu">
    <PageHeader eyebrow="Service" title={service.titre} subtitle={service.tagline} image={img} />

    <section class="mx-auto grid max-w-6xl gap-12 px-5 py-14 md:grid-cols-[1.3fr_1fr] md:py-20">
      <div>
        <p class="text-lg leading-relaxed text-black/75">{service.intro}</p>

        <h2 class="mt-10 font-display text-2xl font-medium text-cfrq-deep">Ce que nous faisons</h2>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {
            service.prestations.map((p) => (
              <li class="flex items-start gap-3 rounded-xl border border-black/5 bg-white p-4 text-[15.5px] leading-snug">
                <svg viewBox="0 0 20 20" class="mt-0.5 h-5 w-5 flex-none text-cfrq-green" aria-hidden="true">
                  <path fill="currentColor" d="M8 13.2 4.8 10l-1.4 1.4L8 16l9-9-1.4-1.4z" />
                </svg>
                <span>{p}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <aside class="space-y-6">
        {
          service.encart && (
            <div class="rounded-2xl bg-cfrq-tint p-6">
              <h2 class="font-display text-lg font-medium text-cfrq-deep">{service.encart.titre}</h2>
              <ul class="mt-4 space-y-3 text-[15px] text-cfrq-ink/80">
                {service.encart.points.map((pt) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-2 h-1.5 w-1.5 flex-none rounded-full bg-cfrq-green" />
                    <span>{pt}</span>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
        <div class="rounded-2xl border border-black/5 bg-cfrq-deep p-6 text-cfrq-cream">
          <h2 class="font-display text-lg font-medium">Un projet en tête ?</h2>
          <p class="mt-2 text-[15px] leading-relaxed text-cfrq-cream/80">
            Nos ingénieurs forestiers évaluent votre situation et vous proposent la meilleure approche.
          </p>
          <a
            href={withBase("/contact")}
            class="mt-4 inline-block rounded-lg bg-cfrq-green px-5 py-3 text-[15px] font-medium text-[#123005] transition-colors hover:bg-cfrq-green-hover"
          >
            Réserver une visite-conseil
          </a>
        </div>
      </aside>
    </section>

    <section class="border-t border-black/5 bg-white/60">
      <div class="mx-auto max-w-6xl px-5 py-14">
        <h2 class="font-display text-2xl font-medium text-cfrq-deep">Autres services</h2>
        <div class="mt-6 grid gap-5 sm:grid-cols-3">
          {
            autres.map((s) => (
              <a
                href={withBase(`/services/${s.slug}`)}
                class="rounded-2xl border border-black/5 bg-white p-6 transition-colors hover:border-cfrq-green/40"
              >
                <h3 class="font-display text-lg font-medium text-cfrq-deep">{s.titre}</h3>
                <p class="mt-2 text-[15px] leading-relaxed text-black/65">{s.tagline}</p>
                <span class="mt-3 inline-block text-[14px] font-medium text-cfrq-leaf">En savoir plus</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <CTASection />
  </main>
  <Footer />
</Base>
