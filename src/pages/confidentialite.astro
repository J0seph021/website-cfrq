---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHeader from "../components/PageHeader.astro";

let html = "";
try {
  const r = await fetch("https://cfrq.ca/wp-json/wp/v2/pages/8962?_fields=content");
  const d = await r.json();
  html = d?.content?.rendered ?? "";
} catch (e) {
  html = "";
}
const fallback =
  "<p>Le contenu de notre politique de confidentialité est en cours de révision. Pour toute question sur le traitement de vos données, écrivez-nous à cfrq@cfrq.ca.</p>";
---

<Base title="Politique de confidentialité — CFRQ" description="Politique de confidentialité et sur les cookies de CFRQ.">
  <Header />
  <main id="contenu">
    <PageHeader eyebrow="Légal" title="Politique de confidentialité et sur les cookies" />
    <section class="contenu-legal mx-auto max-w-3xl px-5 py-14 md:py-16" set:html={html || fallback}></section>
  </main>
  <Footer />
</Base>
