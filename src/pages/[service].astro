---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { services, type Service } from "../data/services";
import { site } from "../data/site";
import { withBase } from "../lib/url";

import peuplement from "../assets/photos/peuplement.jpg";
import foretTravaux from "../assets/photos/foret-travaux.jpg";
import erabliere from "../assets/photos/erabliere.jpg";
import heroRecolte from "../assets/photos/hero-recolte.jpg";
import territoire from "../assets/photos/territoire.jpg";

const imgMap = {
  peuplement,
  "foret-travaux": foretTravaux,
  erabliere,
  "hero-recolte": heroRecolte,
  territoire,
};

// Routes racine calquees sur les URLs WordPress historiques (SEO preserve) :
// /amenagement/, /operation-forestieres/, /evaluation-forestiere/, /erabliere/,
// /arboriculture-et-foresterie-urbaine/, /service-aux-entrepreneurs-en-travaux-sylvicoles/
export function getStaticPaths() {
  return services.map((s) => ({ params: { service: s.slug }, props: { service: s } }));
}

interface Props {
  service: Service;
}
const { service } = Astro.props;
const img = imgMap[service.image];
const autres = services.filter((s) => s.slug !== service.slug).slice(0, 3);
const eyebrow = "text-[12.5px] font-semibold uppercase tracking-[0.18em]";
---

<Base
  title={`${service.titre} | CFRQ`}
  description={service.intro}
  canonical={`/${service.slug}/`}
>
  <Header />
  <main id="contenu">
    <!-- HERO -->
    <section class="relative isolate overflow-hidden bg-[#16200f]">
      <Image src={img} alt={service.titre} widths={[768, 1280, 1920]} sizes="100vw" loading="eager" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10" style="background:linear-gradient(120deg,rgba(15,22,10,.9) 0%,rgba(15,22,10,.66) 55%,rgba(15,22,10,.3) 100%)"></div>
      <div class="mx-auto max-w-[1160px] px-[22px] py-[88px]">
        <div class="max-w-[640px]">
          <p class={`${eyebrow} tracking-[0.2em] text-cfrq-green-light`}>Service</p>
          <h1 class="mt-3 font-display font-medium text-cfrq-cream text-[clamp(34px,5.5vw,52px)] leading-[1.05] tracking-[-0.02em] text-balance">{service.titre}</h1>
          <p class="mt-4 text-[19px] leading-[1.5] text-[#dce2d2]">{service.tagline}</p>
        </div>
      </div>
    </section>

    <!-- CORPS -->
    <section class="mx-auto grid max-w-[1160px] gap-12 px-[22px] py-[72px] md:grid-cols-[1.3fr_1fr]">
      <div>
        <p class="text-[17px] leading-[1.7] text-cfrq-ink/[.75]">{service.intro}</p>

        <h2 class="mt-10 font-display text-[26px] font-medium text-cfrq-deep">Ce que nous faisons</h2>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {service.prestations.map((p) => (
            <li class="flex items-start gap-3 rounded-[14px] border border-black/5 bg-white p-4 text-[15px] leading-snug">
              <svg viewBox="0 0 20 20" class="mt-0.5 h-5 w-5 flex-none text-cfrq-green" aria-hidden="true">
                <path fill="currentColor" d="M8 13.2 4.8 10l-1.4 1.4L8 16l9-9-1.4-1.4z" />
              </svg>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>

      <aside class="space-y-6">
        {service.encart && (
          <div class="rounded-[18px] border border-cfrq-green/[.14] bg-[#eef2e6] p-6">
            <h2 class="font-display text-[19px] font-medium text-cfrq-deep">{service.encart.titre}</h2>
            <ul class="mt-4 space-y-3">
              {service.encart.points.map((pt) => (
                <li class="flex items-start gap-[11px]">
                  <span class="mt-[7px] h-[7px] w-[7px] flex-none rounded-full bg-cfrq-green" />
                  <span class="text-[14.5px] leading-[1.5] text-cfrq-ink">{pt}</span>
                </li>
              ))}
            </ul>
          </div>
        )}
        <div class="rounded-[18px] bg-cfrq-deep p-6 text-cfrq-cream">
          <h2 class="font-display text-[19px] font-medium">Un projet en tête ?</h2>
          <p class="mt-2 text-[15px] leading-relaxed text-cfrq-cream/80">
            Nos ingénieurs forestiers évaluent votre situation et vous proposent la meilleure approche.
          </p>
          <a href={withBase("/contact")} class="mt-4 inline-flex rounded-[11px] bg-cfrq-green px-5 py-3 text-[15px] font-semibold text-[#123005] transition-colors hover:bg-cfrq-green-hover">
            Réserver une visite-conseil
          </a>
        </div>
      </aside>
    </section>

    <!-- AUTRES SERVICES -->
    <section class="border-t border-black/5 bg-white/60">
      <div class="mx-auto max-w-[1160px] px-[22px] py-[60px]">
        <h2 class="font-display text-[26px] font-medium text-cfrq-deep">Autres services</h2>
        <div class="mt-6 grid gap-5 sm:grid-cols-3">
          {autres.map((s) => (
            <a href={withBase(`/${s.slug}`)} class="group rounded-[18px] border border-black/5 bg-white p-6 transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-1 hover:border-cfrq-green/40 hover:shadow-[0_16px_40px_rgba(20,51,26,.1)]">
              <h3 class="font-display text-[19px] font-medium text-cfrq-deep">{s.titre}</h3>
              <p class="mt-2 text-[14.5px] leading-relaxed text-cfrq-ink/65">{s.tagline}</p>
              <span class="mt-3 inline-block text-[14px] font-semibold text-cfrq-leaf">En savoir plus →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="mx-auto max-w-[1160px] px-[22px] py-[72px]">
      <div class="flex flex-wrap items-center justify-between gap-6 rounded-3xl px-[clamp(30px,5vw,52px)] py-[clamp(30px,5vw,52px)] text-cfrq-cream" style="background:linear-gradient(140deg,#1D4011,#14331A)">
        <div class="flex-1 basis-[380px]">
          <h2 class="font-display text-[clamp(28px,4vw,40px)] font-medium leading-[1.08] text-balance">Un projet pour votre boisé ?</h2>
          <p class="mt-3 max-w-[440px] text-[17px] leading-[1.55] text-cfrq-cream/[.82]">Une visite-conseil de votre boisé, c'est le meilleur point de départ.</p>
        </div>
        <div class="flex flex-none flex-wrap items-center gap-3.5">
          <a href={withBase("/contact")} class="inline-flex items-center rounded-xl bg-cfrq-green px-[26px] py-[15px] text-[16px] font-bold text-[#123005] transition-colors hover:bg-[#6ecb3e]">Réserver une visite-conseil</a>
          <p class="text-[16px] text-cfrq-cream/85">ou&nbsp;<a href={site.telHref} class="font-semibold text-white hover:underline">{site.tel}</a></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
