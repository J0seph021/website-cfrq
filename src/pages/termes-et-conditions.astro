---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

let html = "";
try {
  const r = await fetch("https://cfrq.ca/wp-json/wp/v2/pages/8964?_fields=content");
  const d = await r.json();
  html = d?.content?.rendered ?? "";
} catch (e) {
  html = "";
}
const fallback =
  "<p>Nos termes et conditions sont en cours de révision. Pour toute question, écrivez-nous à cfrq@cfrq.ca.</p>";
---

<Base
  title="Termes et conditions | CFRQ"
  description="Conditions générales d'utilisation du site cfrq.ca, Conseillers Forestiers de la Région de Québec inc."
  canonical="/termes-et-conditions/"
>
  <Header />
  <main id="contenu">
    <section style="background:linear-gradient(160deg,#EAF4E0,#F7F5EE 60%)">
      <div class="mx-auto max-w-[820px] px-[22px] pb-10 pt-16">
        <p class="text-[12.5px] font-semibold uppercase tracking-[0.2em] text-cfrq-leaf">Légal</p>
        <h1 class="mt-3.5 font-display font-medium text-cfrq-deep text-[clamp(34px,5.5vw,50px)] leading-[1.04] tracking-[-0.02em] text-balance">
          Termes et conditions
        </h1>
        <p class="mt-4 max-w-[560px] text-[17px] leading-[1.55] text-cfrq-ink/65">
          Conditions générales d'utilisation du site cfrq.ca.
        </p>
      </div>
    </section>

    <section class="contenu-legal mx-auto max-w-[820px] px-[22px] pb-5 pt-12" set:html={html || fallback}></section>
  </main>
  <Footer />
</Base>
