---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PageHeader from "../components/PageHeader.astro";

let html = "";
try {
  const r = await fetch("https://cfrq.ca/wp-json/wp/v2/pages/8964?_fields=content");
  const d = await r.json();
  html = d?.content?.rendered ?? "";
} catch (e) {
  html = "";
}
const fallback =
  "<p>Nos termes et conditions sont en cours de révision. Pour toute question, écrivez-nous à cfrq@cfrq.ca.</p>";
---

<Base title="Termes et conditions — CFRQ" description="Termes et conditions d'utilisation du site de CFRQ.">
  <Header />
  <main id="contenu">
    <PageHeader eyebrow="Légal" title="Termes et conditions" />
    <section class="contenu-legal mx-auto max-w-3xl px-5 py-14 md:py-16" set:html={html || fallback}></section>
  </main>
  <Footer />
</Base>
