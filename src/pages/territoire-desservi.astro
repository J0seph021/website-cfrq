---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
import { withBase } from "../lib/url";
import territoire from "../assets/photos/territoire.jpg";

const regions = [
  { nom: "Québec (Capitale-Nationale)", texte: "Notre base : boisés périurbains, de villégiature et érablières.", base: true },
  { nom: "Portneuf", texte: "Grands boisés privés et érablières productives." },
  { nom: "Charlevoix", texte: "Forêts de montagne et paysages à protéger." },
  { nom: "Côte-Nord", texte: "Grands territoires résineux." },
  { nom: "Mauricie", texte: "Forêt mixte et forte tradition forestière." },
  { nom: "Bois-Francs", texte: "Boisés agricoles et érablières." },
  { nom: "Chaudière", texte: "Boisés de ferme et forte production de bois." },
  { nom: "Appalaches", texte: "Boisés de montagne et longue tradition sylvicole." },
];

// Marqueurs « régions » de la carte stylisée (positions en %).
const marqueurs = [
  { left: "24%", top: "62%" },
  { left: "60%", top: "30%" },
  { left: "72%", top: "56%" },
  { left: "30%", top: "30%" },
];

const carteBg =
  "background:radial-gradient(circle at 42% 44%,rgba(90,189,42,.18),rgba(90,189,42,0) 46%),radial-gradient(circle at 66% 60%,rgba(46,112,22,.16),rgba(46,112,22,0) 46%),repeating-linear-gradient(0deg,rgba(20,51,26,.05) 0 1px,transparent 1px 32px),repeating-linear-gradient(90deg,rgba(20,51,26,.05) 0 1px,transparent 1px 32px),#EEF4E5";

const ld = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "WebPage", "@id": "https://cfrq.ca/territoire-desservi/#webpage", url: "https://cfrq.ca/territoire-desservi/", name: "Territoire desservi | CFRQ", description: "Les huit régions desservies par CFRQ dans la grande région de Québec et l'est du Québec.", inLanguage: "fr-CA", about: { "@id": "https://cfrq.ca/#organization" } },
    { "@type": "BreadcrumbList", itemListElement: [
      { "@type": "ListItem", position: 1, name: "Accueil", item: "https://cfrq.ca/" },
      { "@type": "ListItem", position: 2, name: "Territoire", item: "https://cfrq.ca/territoire-desservi/" },
    ] },
    { "@type": "Organization", "@id": "https://cfrq.ca/#organization", areaServed: [
      { "@type": "AdministrativeArea", name: "Capitale-Nationale (Québec)" },
      { "@type": "AdministrativeArea", name: "Portneuf" },
      { "@type": "AdministrativeArea", name: "Charlevoix" },
      { "@type": "AdministrativeArea", name: "Côte-Nord" },
      { "@type": "AdministrativeArea", name: "Mauricie" },
      { "@type": "AdministrativeArea", name: "Bois-Francs" },
      { "@type": "AdministrativeArea", name: "Chaudière" },
      { "@type": "AdministrativeArea", name: "Appalaches" },
    ] },
  ],
};

const eyebrow = "text-[12.5px] font-semibold uppercase tracking-[0.18em]";
---

<Base
  title="Territoire desservi : région de Québec et est du Québec | CFRQ"
  description="CFRQ dessert huit régions : Québec (Capitale-Nationale), Portneuf, Charlevoix, Côte-Nord, Mauricie, Bois-Francs, Chaudière et Appalaches. Bureau à L'Ancienne-Lorette."
  canonical="/territoire-desservi/"
>
  <script type="application/ld+json" set:html={JSON.stringify(ld)} slot="head" />

  <Header />
  <main id="contenu">
    <!-- HERO -->
    <section class="relative isolate overflow-hidden bg-[#16200f]">
      <Image src={territoire} alt="Territoire forestier" widths={[768, 1280, 1920]} sizes="100vw" loading="eager" class="absolute inset-0 -z-10 h-full w-full object-cover" />
      <div class="absolute inset-0 -z-10" style="background:linear-gradient(120deg,rgba(15,22,10,.9) 0%,rgba(15,22,10,.62) 60%,rgba(15,22,10,.28) 100%)"></div>
      <div class="mx-auto max-w-[1160px] px-[22px] py-[84px]">
        <div class="max-w-[640px]">
          <p class={`${eyebrow} tracking-[0.2em] text-cfrq-green-light`}>Notre territoire</p>
          <h1 class="mt-3 font-display font-medium text-cfrq-cream text-[clamp(38px,6.5vw,58px)] leading-[1.03] tracking-[-0.02em] text-balance">
            La grande région de Québec, et au-delà
          </h1>
          <p class="mt-5 max-w-[540px] text-[19px] leading-[1.55] text-[#dce2d2] text-pretty">
            Nos techniciens et ingénieurs forestiers se déplacent dans huit régions. Où que soit votre boisé, on vient le voir.
          </p>
        </div>
      </div>
    </section>

    <!-- CARTE + BUREAU -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-5 pt-14">
      <div class="flex flex-wrap items-stretch gap-5">
        <div class="relative min-h-[360px] flex-[1.6] basis-[380px] overflow-hidden rounded-3xl border border-black/5" style={carteBg}>
          <span class="absolute h-[18px] w-[18px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-cfrq-deep" style="left:42%;top:44%;box-shadow:0 0 0 6px rgba(20,51,26,.18)"></span>
          <span class="absolute whitespace-nowrap rounded-[7px] bg-white/90 px-[9px] py-[3px] text-[12px] font-semibold text-cfrq-deep" style="left:42%;top:44%;transform:translate(-50%,14px)">Bureau · L'Ancienne-Lorette</span>
          {marqueurs.map((m) => (
            <span class="absolute h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cfrq-green" style={`left:${m.left};top:${m.top};box-shadow:0 0 0 5px rgba(90,189,42,.22)`}></span>
          ))}
          <span class="absolute bottom-3.5 left-4 rounded-lg bg-white/85 px-[11px] py-[5px] text-[12px] font-medium text-cfrq-deep">Carte du territoire desservi</span>
        </div>

        <div class="flex-1 basis-[260px] rounded-3xl bg-cfrq-deep p-[30px] text-cfrq-cream">
          <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-cfrq-green-light">Notre bureau</p>
          <h2 class="mt-3.5 font-display text-[22px] font-medium">L'Ancienne-Lorette</h2>
          <address class="mt-2 text-[15px] not-italic leading-[1.55] text-cfrq-cream/[.82]">
            {site.adresse.ligne1}<br />
            {site.adresse.ville} {site.adresse.code}
          </address>
          <hr class="my-[22px] border-white/[.12]" />
          <p class="text-[15px] leading-[1.6] text-cfrq-cream/[.82]">
            On se déplace sur votre propriété, peu importe la région, pour une <strong class="font-semibold text-white">visite-conseil</strong>.
          </p>
          <a href={withBase("/contact")} class="mt-[18px] inline-flex items-center gap-1.5 rounded-[10px] bg-cfrq-green px-5 py-3 text-[14.5px] font-bold text-[#123005] transition-colors hover:bg-[#6ecb3e]">
            Prendre rendez-vous <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- REGIONS -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-5 pt-16">
      <div class="max-w-[620px]">
        <p class={`${eyebrow} text-cfrq-leaf`}>Huit régions</p>
        <h2 class="mt-3.5 font-display font-medium text-cfrq-deep text-[clamp(30px,4.5vw,42px)] leading-[1.05] tracking-[-0.015em] text-balance">Là où on intervient</h2>
      </div>
      <div class="mt-[38px] grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {regions.map((r) => (
          <div class="rounded-2xl border border-black/5 bg-white p-[22px]">
            <div class="flex items-center gap-[9px]">
              <span class:list={["h-[9px] w-[9px] flex-none rounded-full", r.base ? "bg-cfrq-deep" : "bg-cfrq-green"]}></span>
              <h3 class="font-display text-[19px] text-cfrq-deep">{r.nom}</h3>
            </div>
            <p class="mt-2.5 text-[13.5px] leading-[1.55] text-cfrq-ink/60">{r.texte}</p>
          </div>
        ))}
        <div class="flex items-center rounded-2xl border border-dashed border-cfrq-green/40 bg-[#eef2e6] p-[22px]">
          <p class="text-[14px] leading-[1.55] text-[#2e6b1e]">
            Votre boisé est ailleurs ? <a href={withBase("/contact")} class="font-semibold underline">Écrivez-nous</a>, on regarde ça ensemble.
          </p>
        </div>
      </div>
    </section>

    <!-- CTA FINAL -->
    <section class="mx-auto max-w-[1160px] px-[22px] pb-[84px] pt-16">
      <div class="rounded-3xl px-[clamp(34px,5vw,56px)] py-[clamp(34px,5vw,56px)] text-center text-cfrq-cream" style="background:linear-gradient(140deg,#1D4011,#14331A)">
        <h2 class="font-display text-[clamp(28px,4.5vw,44px)] font-medium leading-[1.06] text-balance">Votre boisé mérite une visite</h2>
        <p class="mx-auto mt-4 max-w-[520px] text-[18px] leading-[1.55] text-cfrq-cream/[.82]">
          Où qu'il soit, un technicien se déplace pour une visite-conseil, sans engagement.
        </p>
        <div class="mt-[30px] flex flex-wrap items-center justify-center gap-4">
          <a href={withBase("/contact")} class="inline-flex items-center rounded-xl bg-cfrq-green px-8 py-4 text-[16.5px] font-bold text-[#123005] transition-colors hover:bg-[#6ecb3e]">Réserver une visite-conseil</a>
          <p class="text-[16px] text-cfrq-cream/85">ou&nbsp;<a href={site.telHref} class="font-semibold text-cfrq-cream hover:underline">{site.tel}</a></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
