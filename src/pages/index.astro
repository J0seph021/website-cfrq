---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TaxCalculator from "../components/TaxCalculator.tsx";

import heroRecolte from "../assets/photos/hero-recolte.jpg";
import erabliere from "../assets/photos/erabliere.jpg";
import peuplement from "../assets/photos/peuplement.jpg";
import foretTravaux from "../assets/photos/foret-travaux.jpg";
import territoire from "../assets/photos/territoire.jpg";

const piliers = [
  {
    titre: "Expertise crédible",
    texte: "Signé par des ingénieurs forestiers membres de l'OIFQ, avec près de 30 ans de pratique.",
  },
  {
    titre: "Indépendance",
    texte: "On travaille pour vous. Aucune coopérative, aucune adhésion, aucune superficie minimale.",
  },
  {
    titre: "Technologie",
    texte: "Cartographie interactive et portail client, propulsés par notre plateforme PlaniLogix.",
  },
];

const services = [
  { titre: "Aménagement forestier", texte: "Plan d'aménagement, éclaircie, jardinage, reboisement.", img: peuplement },
  { titre: "Érablière et acériculture", texte: "Plan d'érablière, conformité d'entaillage, CPTAQ, cartographie.", img: erabliere },
  { titre: "Évaluation et expertise légale", texte: "Expropriation, servitudes, témoin expert, dommages.", img: null },
  { titre: "Foresterie urbaine", texte: "Études de canopée, arbres à risque, accompagnement de promoteurs.", img: null },
  { titre: "Succession et transfert", texte: "Transfert intergénérationnel, planification, partenaires notaires.", img: null },
  { titre: "Opérations forestières", texte: "Récolte, voirie forestière, mise en marché du bois.", img: foretTravaux },
];

const stats = [
  "5 ingénieurs forestiers (OIFQ)",
  "3 000+ clients accompagnés",
  "6 agences, partout au Québec",
  "Conseiller indépendant",
];
---

<Base>
  <Header />
  <main id="contenu">
    <!-- Héro -->
    <section class="relative isolate overflow-hidden">
      <Image
        src={heroRecolte}
        alt="Travaux de récolte forestière en forêt privée au Québec"
        widths={[768, 1280, 1920, 2560]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
        class="absolute inset-0 -z-10 h-full w-full object-cover"
      />
      <div class="absolute inset-0 -z-10 bg-cfrq-deep/78"></div>

      <div class="mx-auto max-w-6xl px-5 py-24 sm:py-28 md:py-36">
        <p class="mb-5 text-[13px] font-medium uppercase tracking-[0.12em] text-cfrq-green">
          Ingénieurs forestiers, OIFQ, depuis 1996
        </p>
        <h1 class="max-w-[18ch] font-display text-4xl font-medium leading-[1.1] text-cfrq-cream sm:text-5xl md:text-6xl">
          Protégez votre boisé. Faites-en un projet de vie en santé.
        </h1>
        <p class="mt-6 max-w-[54ch] text-lg leading-relaxed text-cfrq-cream/85">
          Votre forestier de famille. Des ingénieurs indépendants qui planifient, cartographient et
          aménagent votre forêt, partout au Québec, sans adhésion ni superficie minimale.
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <a
            href="#calculateur"
            class="rounded-lg bg-cfrq-green px-6 py-3.5 text-[16px] font-medium text-[#123005] transition-colors hover:bg-cfrq-green-hover"
          >
            Calculer mon remboursement de taxes
          </a>
          <a
            href="#contact"
            class="rounded-lg border border-cfrq-cream/50 px-6 py-3.5 text-[16px] font-medium text-cfrq-cream transition-colors hover:bg-cfrq-cream/10"
          >
            Réserver une visite-conseil
          </a>
        </div>
      </div>
    </section>

    <!-- Barre de confiance -->
    <section class="bg-cfrq-deep-2 text-cfrq-cream">
      <div class="mx-auto flex max-w-6xl flex-wrap justify-between gap-x-8 gap-y-3 px-5 py-5 text-[15px]">
        {stats.map((s) => (
          <span class="flex items-center gap-2">
            <svg viewBox="0 0 20 20" class="h-4 w-4 flex-none text-cfrq-green" aria-hidden="true">
              <path fill="currentColor" d="M8 13.2 4.8 10l-1.4 1.4L8 16l9-9-1.4-1.4z" />
            </svg>
            {s}
          </span>
        ))}
      </div>
    </section>

    <!-- Piliers -->
    <section id="a-propos" class="mx-auto max-w-6xl px-5 py-16 md:py-20">
      <div class="grid gap-6 md:grid-cols-3">
        {piliers.map((p) => (
          <div class="rounded-2xl border border-black/5 bg-white p-7">
            <h2 class="font-display text-xl font-medium text-cfrq-deep">{p.titre}</h2>
            <p class="mt-3 text-[15.5px] leading-relaxed text-black/70">{p.texte}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Calculateur (outil phare) -->
    <section id="calculateur" class="bg-white/60">
      <div class="mx-auto max-w-6xl px-5 py-16 md:py-20">
        <p class="mb-2 text-[13px] font-medium uppercase tracking-[0.1em] text-cfrq-leaf">
          Outil, estimation gratuite
        </p>
        <h2 class="font-display text-3xl font-medium text-cfrq-deep md:text-4xl">
          Combien pourriez-vous récupérer en taxes ?
        </h2>
        <p class="mb-8 mt-3 max-w-[60ch] text-[16px] leading-relaxed text-black/70">
          Un producteur forestier reconnu peut récupérer jusqu'à 85 % des taxes foncières de son
          boisé grâce à des travaux d'aménagement admissibles. Bougez les curseurs pour estimer.
        </p>
        <TaxCalculator client:load />
      </div>
    </section>

    <!-- Services -->
    <section id="services" class="mx-auto max-w-6xl px-5 py-16 md:py-20">
      <h2 class="font-display text-3xl font-medium text-cfrq-deep md:text-4xl">Nos services</h2>
      <p class="mb-8 mt-3 max-w-[60ch] text-[16px] leading-relaxed text-black/70">
        De la santé de votre forêt jusqu'aux mandats les plus techniques, signés par des ingénieurs.
      </p>
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((s) => (
          <article class="overflow-hidden rounded-2xl border border-black/5 bg-white">
            {s.img && (
              <Image
                src={s.img}
                alt={s.titre}
                widths={[400, 800]}
                sizes="(min-width: 1024px) 360px, (min-width: 640px) 50vw, 100vw"
                class="h-40 w-full object-cover"
              />
            )}
            <div class="p-6">
              <h3 class="font-display text-lg font-medium text-cfrq-deep">{s.titre}</h3>
              <p class="mt-2 text-[15px] leading-relaxed text-black/65">{s.texte}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- Teaser carte du territoire -->
    <section id="ressources" class="relative isolate overflow-hidden">
      <Image
        src={territoire}
        alt="Territoire desservi par CFRQ"
        widths={[768, 1280, 1920]}
        sizes="100vw"
        class="absolute inset-0 -z-10 h-full w-full object-cover"
      />
      <div class="absolute inset-0 -z-10 bg-cfrq-deep/85"></div>
      <div class="mx-auto max-w-6xl px-5 py-20 text-center">
        <h2 class="mx-auto max-w-[22ch] font-display text-3xl font-medium text-cfrq-cream md:text-4xl">
          Une carte interactive de votre territoire
        </h2>
        <p class="mx-auto mt-4 max-w-[58ch] text-[16px] leading-relaxed text-cfrq-cream/85">
          Capitale-Nationale, Charlevoix, Côte-Nord, Mauricie. Bientôt, explorez votre secteur sur
          une carte vivante, alimentée par nos propres couches PlaniLogix.
        </p>
        <a
          href="#contact"
          class="mt-8 inline-block rounded-lg bg-cfrq-green px-6 py-3.5 text-[16px] font-medium text-[#123005] transition-colors hover:bg-cfrq-green-hover"
        >
          Parler à un ingénieur forestier
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Base>
