---
import Logo from "./Logo.astro";
import { withBase } from "../lib/url";
import { site } from "../data/site";

const nav = [
  { label: "Accueil", href: "/" },
  { label: "Services", href: "/services" },
  { label: "Territoire", href: "/territoire-desservi" },
  { label: "À propos", href: "/a-propos-de-nous" },
  { label: "Contact", href: "/contact" },
];

// Chemin courant normalisé (sans la base ni le slash final) pour l'état actif.
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const raw = Astro.url.pathname.replace(base, "") || "/";
const current = raw !== "/" ? raw.replace(/\/$/, "") : "/";
const isActive = (href: string) =>
  href === "/" ? current === "/" : current === href || current.startsWith(`${href}/`);
---

<header class="sticky top-0 z-40 border-b border-black/5 bg-white/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-[1160px] items-center justify-between gap-4 px-[22px] py-3.5" aria-label="Navigation principale">
    <a href={withBase("/")} class="flex items-center text-cfrq-ink" aria-label="Accueil CFRQ">
      <Logo class="h-9 w-auto" />
    </a>

    <ul class="hidden items-center gap-8 text-[15px] font-medium lg:flex">
      {nav.map((l) => (
        <li>
          <a
            href={withBase(l.href)}
            aria-current={isActive(l.href) ? "page" : undefined}
            class:list={[
              "py-2 transition-colors",
              isActive(l.href)
                ? "text-cfrq-green underline decoration-2 underline-offset-[6px]"
                : "text-cfrq-deep hover:text-cfrq-green",
            ]}
          >
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-4">
      <a
        href={withBase("/espace-client")}
        class="hidden text-[15px] font-medium text-cfrq-deep transition-colors hover:text-cfrq-green sm:inline"
      >
        Espace client
      </a>
      <a
        href={withBase("/contact")}
        class="hidden rounded-[10px] bg-cfrq-green px-5 py-2.5 text-[15px] font-semibold text-cfrq-deep transition-colors hover:bg-cfrq-green-hover sm:inline"
      >
        Nous joindre
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-black/10 text-cfrq-deep lg:hidden"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg viewBox="0 0 24 24" class="h-6 w-6" aria-hidden="true"><path fill="currentColor" d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z" /></svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-black/5 bg-white lg:hidden">
    <ul class="mx-auto max-w-[1160px] px-[22px] py-3 text-[16px] text-cfrq-deep">
      {nav.map((l) => (
        <li>
          <a
            href={withBase(l.href)}
            aria-current={isActive(l.href) ? "page" : undefined}
            class:list={["block py-2.5", isActive(l.href) && "font-medium text-cfrq-green"]}
          >
            {l.label}
          </a>
        </li>
      ))}
      <li><a href={withBase("/espace-client")} class="block py-2.5">Espace client</a></li>
      <li class="pt-2 pb-1">
        <a href={site.telHref} class="block rounded-[10px] bg-cfrq-green px-4 py-3 text-center font-semibold text-cfrq-deep">
          Nous joindre, {site.tel}
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
    btn.setAttribute("aria-label", open ? "Fermer le menu" : "Ouvrir le menu");
  });
</script>
